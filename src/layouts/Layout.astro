---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedDate?: string;
  updatedDate?: string;
  breadcrumbs?: Array<{ name: string; href: string }>;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>> | null;
}

const {
  title,
  description = 'AEVO Ada – Die smarte App zur AEVO-Prüfungsvorbereitung. 700+ Prüfungsfragen, realistische Simulationen und ein intelligentes Lernsystem für angehende Ausbilder.',
  canonical,
  keywords = 'AEVO Prüfung, AEVO Prüfungsvorbereitung, Ausbilder-Eignungsverordnung, AEVO App, AEVO Lernen, AEVO Fragen, Ausbilder Prüfung, IHK AEVO',
  ogImage: ogImageProp = 'og-image.png',
  ogType = 'website',
  noindex = false,
  publishedDate,
  updatedDate,
  breadcrumbs,
  jsonLd,
} = Astro.props;

const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const siteOrigin = Astro.site
  ? `${new URL(Astro.site).origin}/`
  : 'https://lumi-zone.github.io/aevo-web/';
const publicRoot = new URL(baseUrl, siteOrigin);
const siteUrl = siteOrigin;
const currentPath = Astro.url.pathname;
const canonicalHref = canonical ?? new URL(currentPath, publicRoot).href;
const ogImage = new URL(ogImageProp, publicRoot).href;
const robotsContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'AEVO Ada',
  description:
    'Die smarte App zur Vorbereitung auf die AEVO-Prüfung (Ausbilder-Eignungsverordnung) mit 700+ Fragen, Prüfungssimulationen und intelligentem Lernalgorithmus.',
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'iOS',
  downloadUrl: 'https://apps.apple.com/de/app/aevo-ihk-app-ada-schein/id6763579448',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Lumi-Zone',
    email: 'cfsmobiletech@gmail.com',
  },
};

const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const appStoreUrl = 'https://apps.apple.com/de/app/aevo-ihk-app-ada-schein/id6763579448';
const appleAppId = '6763579448';
const defaultUmamiWebsiteId = '688db29c-e411-4983-8eb8-6667eb5eeb6b';
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID?.trim() || defaultUmamiWebsiteId;
const umamiScriptUrl = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL?.trim() || 'https://cloud.umami.is/script.js';
const umamiDomains = import.meta.env.PUBLIC_UMAMI_DOMAINS?.trim() || 'aevo-ada-pruefung.de';
const navLinks = [
  { href: base, label: 'Startseite' },
  { href: `${base}aevo-pruefung/`, label: 'AEVO Prüfung' },
  { href: `${base}aevo-pruefungsfragen/`, label: 'Prüfungsfragen' },
  { href: `${base}ausbilderschein-ada-schein/`, label: 'ADA-Schein' },
  { href: `${base}support/`, label: 'Support' },
];

const isActive = (href: string) => {
  const path = Astro.url.pathname;
  if (href === base) return path === base || path === base.slice(0, -1);
  return path.startsWith(href) || path.startsWith(href.slice(0, -1));
};

const breadcrumbJsonLd = breadcrumbs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: new URL(item.href, publicRoot).href,
      })),
    }
  : null;

const pageJsonLd = jsonLd === undefined ? defaultJsonLd : jsonLd;
const jsonLdEntries = [
  ...(Array.isArray(pageJsonLd) ? pageJsonLd : pageJsonLd ? [pageJsonLd] : []),
  ...(breadcrumbJsonLd ? [breadcrumbJsonLd] : []),
];
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Lumi-Zone" />
    <link rel="canonical" href={canonicalHref} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="AEVO Ada" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AEVO Ada – AEVO Prüfungsvorbereitung App" />
    {ogType === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {ogType === 'article' && updatedDate && <meta property="article:modified_time" content={updatedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${baseUrl}apple-touch-icon.png`} />
    <meta name="apple-itunes-app" content={`app-id=${appleAppId}, app-argument=${canonicalHref}`} />

    <!-- Structured Data -->
    {jsonLdEntries.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    {umamiWebsiteId && (
      <script
        is:inline
        defer
        src={umamiScriptUrl}
        data-website-id={umamiWebsiteId}
        data-domains={umamiDomains || undefined}
      ></script>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>

    <!-- Navigation -->
    <header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-cream/90 backdrop-blur-md border-b border-cream-border">
      <div
        id="mobile-app-banner"
        class="md:hidden border-b border-cream-border bg-card"
        hidden
      >
        <div class="max-w-5xl mx-auto px-3 py-2.5 flex items-center gap-3">
          <button
            id="mobile-app-banner-close"
            type="button"
            class="flex-shrink-0 w-8 h-8 rounded-full text-muted hover:text-brown hover:bg-cream-dark transition-colors flex items-center justify-center"
            aria-label="App-Banner schließen"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>

          <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-wine flex items-center justify-center shadow-sm">
            <span class="text-gold font-serif font-bold text-base">A</span>
          </div>

          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-brown leading-tight truncate">AEVO Ada</p>
            <p class="text-xs text-muted leading-tight truncate">AEVO-Prüfung mobil lernen</p>
          </div>

          <a
            href={appStoreUrl}
            class="flex-shrink-0 inline-flex items-center justify-center bg-wine text-cream px-4 py-2 rounded-full text-xs font-bold hover:bg-wine-dark transition-colors"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="AEVO Ada App öffnen"
            data-umami-event="app-store-click"
            data-umami-event-location="mobile-app-banner"
          >
            Öffnen
          </a>
        </div>
      </div>

      <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href={baseUrl} class="flex items-center gap-2 group" aria-label="AEVO Ada – Startseite">
          <div class="w-8 h-8 rounded-xl bg-wine flex items-center justify-center shadow-sm">
            <span class="text-gold font-serif font-bold text-sm">A</span>
          </div>
          <span class="font-serif font-bold text-wine text-lg group-hover:text-wine-dark transition-colors">AEVO Ada</span>
        </a>

        <!-- Desktop Nav -->
        <ul class="hidden md:flex items-center gap-5" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`text-sm font-medium transition-colors hover:text-wine ${
                  isActive(href)
                    ? 'text-wine font-semibold'
                    : 'text-muted'
                }`}
                aria-current={isActive(href) ? 'page' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="md:hidden p-2 rounded-lg text-muted hover:text-wine hover:bg-cream-dark transition-colors"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-cream-border bg-cream">
        <ul class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1" role="list">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class={`block px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                  isActive(href)
                    ? 'bg-wine/10 text-wine font-semibold'
                    : 'text-muted hover:bg-cream-dark hover:text-brown'
                }`}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>

    <main id="main-content" tabindex="-1" class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-brown text-cream/80 mt-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-8 mb-10">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <div class="w-7 h-7 rounded-lg bg-wine flex items-center justify-center">
                <span class="text-gold font-serif font-bold text-xs">A</span>
              </div>
              <span class="font-serif font-bold text-cream text-base">AEVO Ada</span>
            </div>
            <p class="text-sm text-cream/60 leading-relaxed">
              Die smarte Lern-App für angehende Ausbilder. Bestehe deine AEVO-Prüfung im ersten Anlauf.
            </p>
          </div>

          <div>
            <h3 class="text-cream font-semibold text-sm mb-3">App</h3>
            <ul class="space-y-2">
              <li>
                <a href={`${base}#features`} class="text-sm text-cream/60 hover:text-cream transition-colors">Funktionen</a>
              </li>
              <li>
                <a href={`${base}#handlungsfelder`} class="text-sm text-cream/60 hover:text-cream transition-colors">Handlungsfelder</a>
              </li>
              <li>
                <a href={`${base}#premium`} class="text-sm text-cream/60 hover:text-cream transition-colors">Premium</a>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="text-cream font-semibold text-sm mb-3">AEVO Lernen</h3>
            <ul class="space-y-2">
              <li>
                <a href={`${base}aevo-pruefung/`} class="text-sm text-cream/60 hover:text-cream transition-colors">AEVO Prüfung</a>
              </li>
              <li>
                <a href={`${base}aevo-pruefungsvorbereitung/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Prüfungsvorbereitung</a>
              </li>
              <li>
                <a href={`${base}aevo-pruefungsfragen/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Prüfungsfragen</a>
              </li>
              <li>
                <a href={`${base}ausbilderschein-ada-schein/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Ausbilderschein / ADA-Schein</a>
              </li>
            </ul>
          </div>

          <div>
            <h3 class="text-cream font-semibold text-sm mb-3">Rechtliches</h3>
            <ul class="space-y-2">
              <li>
                <a href={`${base}datenschutz/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Datenschutzerklärung</a>
              </li>
              <li>
                <a href={`${base}nutzungsbedingungen/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Nutzungsbedingungen</a>
              </li>
              <li>
                <a href={`${base}support/`} class="text-sm text-cream/60 hover:text-cream transition-colors">Support</a>
              </li>
              <li>
                <a
                  href="mailto:cfsmobiletech@gmail.com"
                  class="text-sm text-cream/60 hover:text-cream transition-colors"
                  data-umami-event="support-email-click"
                  data-umami-event-location="footer"
                >
                  Kontakt
                </a>
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-cream/10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
          <p class="text-xs text-cream/40">
            &copy; {new Date().getFullYear()} AEVO Ada · Lumi-Zone. Alle Rechte vorbehalten.
          </p>
          <p class="text-xs text-cream/40">
            Für angehende Ausbilder in Deutschland
          </p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const appBanner = document.getElementById('mobile-app-banner');
      const appBannerClose = document.getElementById('mobile-app-banner-close');
      const isMobileDevice = /Android|iPhone|iPad|iPod|Mobile/i.test(navigator.userAgent);
      const isMobileViewport = window.matchMedia('(max-width: 767px)').matches;
      const appBannerStorageKey = 'aevo-app-banner-dismissed';
      const isAppBannerDismissed = (() => {
        try {
          return localStorage.getItem(appBannerStorageKey) === 'true';
        } catch {
          return false;
        }
      })();

      if (appBanner && (isMobileDevice || isMobileViewport) && !isAppBannerDismissed) {
        appBanner.hidden = false;
        document.body.classList.add('has-mobile-app-banner');
      }

      appBannerClose?.addEventListener('click', () => {
        appBanner?.setAttribute('hidden', '');
        document.body.classList.remove('has-mobile-app-banner');
        try {
          localStorage.setItem(appBannerStorageKey, 'true');
        } catch {}
      });

      btn?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        menu?.classList.toggle('hidden', isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
        btn.setAttribute('aria-label', isOpen ? 'Menü öffnen' : 'Menü schließen');
      });
    </script>

    <style>
      .skip-link {
        position: fixed;
        top: 0.75rem;
        left: 0.75rem;
        padding: 0.5rem 0.75rem;
        background: #7B1E22;
        color: #F7EFE3;
        border-radius: 0.5rem;
        font-weight: 600;
        text-decoration: none;
        transform: translateY(-180%);
        transition: transform 150ms ease;
        z-index: 10000;
      }
      .skip-link:focus {
        transform: translateY(0);
      }

      @media (max-width: 767px) {
        body.has-mobile-app-banner #main-content {
          padding-top: 8.75rem;
        }
      }
    </style>
  </body>
</html>
